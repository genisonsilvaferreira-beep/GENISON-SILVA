// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// AUTHENTICATION & USERS
model User {
  id                    String     @id @default(cuid())
  email                 String     @unique
  name                  String?
  password              String?
  avatar                String?
  role                  UserRole   @default(USER)
  isEmailVerified       Boolean    @default(false)
  isActive              Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?

  // Relations
  favorites             Favorite[]
  clicks                Click[]
  affiliateLinks        AffiliateLink[]
  sessions              Session[]

  @@index([email])
  @@index([role])
}

enum UserRole {
  USER
  EDITOR
  ADMIN
}

model Session {
  id            String     @id @default(cuid())
  sessionToken  String     @unique
  userId        String
  expires       DateTime
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// CATEGORIES
model Category {
  id            String     @id @default(cuid())
  name          String     @unique
  slug          String     @unique
  description   String?
  icon          String?
  image         String?
  color         String?
  order         Int        @default(0)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  products      Product[]
  banners       Banner[]

  @@index([slug])
  @@index([isActive])
}

// STORES
model Store {
  id                    String     @id @default(cuid())
  name                  String     @unique
  slug                  String     @unique
  description           String?
  logo                  String?
  banner                String?
  website               String?
  color                 String?
  order                 Int        @default(0)
  isActive              Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  // Relations
  products              Product[]
  coupons               Coupon[]
  affiliateLinks        AffiliateLink[]

  @@index([slug])
  @@index([isActive])
}

// PRODUCTS/OFFERS
model Product {
  id                    String     @id @default(cuid())
  title                 String
  slug                  String     @unique
  description           String?
  image                 String?
  gallery               String[]   @default([])
  currentPrice          Float
  originalPrice         Float?
  discountPercentage    Int?
  url                   String     @unique
  rating                Float      @default(0)
  reviews               Int        @default(0)
  shipping              String?
  badge                 Badge      @default(NEW)
  isActive              Boolean    @default(true)
  isFeatured            Boolean    @default(false)
  views                 Int        @default(0)
  clicks                Int        @default(0)
  favorites             Int        @default(0)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  expiresAt             DateTime?

  // Foreign Keys
  categoryId            String
  storeId               String

  // Relations
  category              Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  store                 Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  favoriteRecords       Favorite[]
  clickRecords          Click[]
  priceHistory          PriceHistory[]
  coupons               Coupon[]   @relation("ProductCoupons")

  @@index([categoryId])
  @@index([storeId])
  @@index([slug])
  @@index([isActive])
  @@index([isFeatured])
  @@index([createdAt])
}

enum Badge {
  NEW
  HOT
  EXCLUSIVE
  BEST_PRICE
  BOT_CHOICE
  FEATURED
  SHIPPING_FREE
}

// PRICE HISTORY
model PriceHistory {
  id                    String     @id @default(cuid())
  price                 Float
  createdAt             DateTime   @default(now())

  // Foreign Keys
  productId             String

  // Relations
  product               Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
}

// COUPONS
model Coupon {
  id                    String     @id @default(cuid())
  code                  String     @unique
  description           String?
  discountType          DiscountType
  discountValue         Float
  maxUses              Int?
  currentUses          Int        @default(0)
  isActive              Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  expiresAt             DateTime?

  // Foreign Keys
  storeId               String
  productIds            String[]   @default([])

  // Relations
  store                 Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products              Product[]  @relation("ProductCoupons")

  @@index([storeId])
  @@index([code])
  @@index([isActive])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// FAVORITES
model Favorite {
  id                    String     @id @default(cuid())
  createdAt             DateTime   @default(now())

  // Foreign Keys
  userId                String
  productId             String

  // Relations
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  product               Product    @relation(fields: [productId], references: [id], onDelete: Cascade, name: "favoriteRecords")

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

// CLICKS
model Click {
  id                    String     @id @default(cuid())
  createdAt             DateTime   @default(now())

  // Foreign Keys
  userId                String?
  productId             String

  // Relations
  user                  User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  product               Product    @relation(fields: [productId], references: [id], onDelete: Cascade, name: "clickRecords")

  @@index([productId])
  @@index([userId])
  @@index([createdAt])
}

// BANNERS
model Banner {
  id                    String     @id @default(cuid())
  title                 String
  description           String?
  image                 String
  link                  String?
  position              Int        @default(0)
  isActive              Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  expiresAt             DateTime?

  // Foreign Keys
  categoryId            String?

  // Relations
  category              Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([categoryId])
}

// CAMPAIGNS
model Campaign {
  id                    String     @id @default(cuid())
  name                  String
  slug                  String     @unique
  description           String?
  banner                String?
  startDate             DateTime
  endDate               DateTime
  isActive              Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([slug])
  @@index([isActive])
}

// AFFILIATE LINKS
model AffiliateLink {
  id                    String     @id @default(cuid())
  code                  String     @unique
  platform              String     // amazon, shopee, mercado_livre, etc
  url                   String
  isActive              Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  // Foreign Keys
  userId                String
  storeId               String

  // Relations
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  store                 Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([storeId])
  @@index([platform])
}

// SYSTEM SETTINGS
model SystemSettings {
  id                    String     @id @default("settings")
  siteName              String     @default("PROMOS DO GS")
  siteDescription       String     @default("As melhores promoções da internet em um só lugar")
  logo                  String?
  favicon               String?
  primaryColor          String     @default("#FFC107")
  secondaryColor        String     @default("#111111")
  maintenanceMode       Boolean    @default(false)
  enableNewsletter      Boolean    @default(true)
  enableAffiliates      Boolean    @default(true)
  updatedAt             DateTime   @updatedAt
}
